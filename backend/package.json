{
    "name": "smartcms-backend",
    "version": "1.0.0",
    "description": "Smart College Management System - Cloudflare Workers Backend",
    "main": "src/index.ts",
    "scripts": {
        "dev": "wrangler dev",
        "deploy": "wrangler deploy",
        "db:migrate": "wrangler d1 execute smartcms-db --local --file=./migrations/0001_init.sql",
        "db:seed": "wrangler d1 execute smartcms-db --local --file=./migrations/0002_seed.sql"
    },
    "dependencies": {},
    "devDependencies": {
        "wrangler": "^4.0.0",
        "@cloudflare/workers-types": "^4.20250224.0",
        "typescript": "^5.7.0"
    }
}